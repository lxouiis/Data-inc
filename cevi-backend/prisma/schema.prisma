generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Doctor {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  name       String
  role       String   @default("radiologist")
  created_at DateTime @default(now())
}

model Patient {
  id             String   @id @default(uuid())
  name           String
  uhid           String   @unique
  age            Int
  sex            String
  height         Float?
  weight         Float?
  bmi            Float?
  race           String?
  smoking        String?
  occupation     String?
  parity         Int?
  comorbidities  String?
  medications    String?
  venous_history String?
  dvt_history    Boolean  @default(false)
  clinic         String?
  doctor_notes   String?
  created_at     DateTime @default(now())
  legs           Leg[]
  assessments    Assessment[]
}

model Assessment {
  id             String    @id @default(uuid())
  patient_id     String
  patient        Patient   @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  assessed_by    String?
  assessment_date DateTime @default(now())
  comorbidities  String?   // JSON
  venous_history String?   // JSON
  clinical_notes String?
  right_pain_vas Int?
  left_pain_vas  Int?
  veines_notes   String?
  global_rvcss   Int       @default(0)
  
  legs           Leg[]
}

model Leg {
  id            Int         @id @default(autoincrement())
  patient_id    String
  patient       Patient     @relation(fields: [patient_id], references: [id], onDelete: Cascade)
  assessment_id String?
  assessment    Assessment? @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  leg_side      String

  // Deep System Doppler
  deep_system              String?
  common_femoral_vein      String?
  superficial_femoral_vein String?
  popliteal_vein           String?
  sfj_reflux               Boolean @default(false)

  // GSV
  gsv_diameter Float?
  gsv_reflux   Boolean @default(false)

  // SSV
  ssv_diameter Float?
  ssv_reflux   Boolean @default(false)

  // Perforators
  incompetent_perforators Boolean @default(false)

  // Clinical Signs (JSON array string)
  clinical_signs String?

  // CEAP
  ceap_c    String?
  ceap_e    String?
  ceap_a    String?
  ceap_p    String?
  ceap_full String?

  // rVCSS parameters (0–3 each)
  pain           Int @default(0)
  varicose_veins Int @default(0)
  edema          Int @default(0)
  pigmentation   Int @default(0)
  inflammation   Int @default(0)
  induration     Int @default(0)
  ulcer_count    Int @default(0)
  ulcer_duration Int @default(0)
  ulcer_size     Int @default(0)
  compression    Int @default(0)
  rvcss_total    Int @default(0)

  // Local Examination — Ulcer
  ulcer_present  Boolean @default(false)
  ulcer_location String?
  ulcer_size_cm  Float?
  ulcer_type     String?
  ulcer_edges    String?
  ulcer_base     String?

  // Skin & Swelling
  skin_changes   String?
  swelling_grade String?

  // Pain VAS
  pain_vas Int?

  // Etiology
  etiology String?

  created_at DateTime  @default(now())
  images     Image[]
  doppler    Doppler[]
}

model Image {
  id          Int      @id @default(autoincrement())
  leg_id      Int
  leg         Leg      @relation(fields: [leg_id], references: [id], onDelete: Cascade)
  file_path   String
  view_type   String
  uploaded_at DateTime @default(now())
}

model Doppler {
  id               Int      @id @default(autoincrement())
  leg_id           Int
  leg              Leg      @relation(fields: [leg_id], references: [id], onDelete: Cascade)
  file_path        String
  file_type        String?
  preview_image    String?
  vein_diameter    Float?
  reflux_time      Float?
  vein_type        String?
  deep_vein_status String?
  uploaded_at      DateTime @default(now())
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  doctor_id   Int?
  doctor_name String?
  action      String   // e.g. "VIEW_PATIENT", "CREATE_ASSESSMENT", "DOWNLOAD_DICOM"
  patient_id  String?
  details     String?  // JSON string of additional context
  timestamp   DateTime @default(now())
}

